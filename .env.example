# pdf2book AI Review 配置模板
# 用法：复制本文件为 .env，填入你的真实 API Key
#   cp .env.example .env  (Linux/macOS)
#   copy .env.example .env  (Windows)
#
# .env 文件已被 .gitignore 排除，不会上传到 GitHub
# config.yaml 中的 ${PDF2BOOK_API_KEY:-} 占位符会自动读取这里的值

# SenseNova (商汤) API Key
PDF2BOOK_API_KEY=sk-your-api-key-here

# 可选：覆盖默认 API URL（默认为 https://token.sensenova.cn）
# PDF2BOOK_API_URL=https://token.sensenova.cn
