# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/
.mypy_cache/

# Build / packaging
dist/
build/
*.egg-info/
*.egg

# Project-specific: workspace directory (regenerable via `pdf2book ocr --resume`)
workspace/

# Project-specific: old/test intermediate directories (regenerable)
.pdf2book/
.pdf2book_test/

# Project-specific: generated EPUB outputs (regenerable)
*.epub

# Project-specific: source PDF inputs (external, do not commit)
PDFeBOOK/
*.pdf

# Standard folders: keep directory structure visible (content ignored above)
!inbox/.gitkeep
!library/.gitkeep

# Tests (excluded from public repo)
tests/
test_config.yaml

# IDE / editor
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Trae agent workspace (keep skills/, exclude the rest)
.trae/*
!.trae/skills/
.trae-html-share-packages/

# Understand-anything knowledge graph cache
.understand-anything/

# Uploads directory
.uploads/

# Sensitive files
*.env
.env.*
!.env.example
*.key
*.pem
